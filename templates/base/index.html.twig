{% extends 'base.html.twig' %}

{% block title %}
	{{ parent() }}
	- Accueil
{% endblock %}

{% block body %}
	{# Section HERO #}
	<div class="hero">
    <div class="container text-center">
        {# Affichage du logo principal #}
        <img src="{{ asset('images/logo/logo_texte.png') }}" 
             alt="Logo LBF Paysage" 
             class="img-fluid mb-4 hero-logo">
        </div>
    </div>
</div>
	{# 1. Définition de ta liste d'images dans l'ordre souhaité #}
	{% set photos_apropos = ['intro.jpg', 'sommeNous.jpg','Service.jpg','secteurGeographique.jpg', 'contactezNous.jpg'] %}

	<section id="a-propos" class="container py-5 reveal">
		<h2 class="text-center fw-bold mb-5">À propos de LBF Paysage</h2>

		{# --- GRILLE DE MINIATURES --- #}
		<div class="row g-4 justify-content-center">
			{% for photo in photos_apropos %}
				<div class="col-md-4 col-sm-6">
					<div class="gallery-item rounded-4 overflow-hidden shadow-sm" data-bs-toggle="modal" data-bs-target="#aproposLightbox" data-bs-slide-to="{{ loop.index0 }}">
						<img src="{{ asset('images/Apropos/' ~ photo) }}" class="img-fluid w-100 h-100 object-fit-cover" alt="LBF Paysage Infos - {{ loop.index }}" style="height: 350px;">
					</div>
				</div>
			{% endfor %}
		</div>
	</section>

		{# --- MODAL LIGHTBOX --- #}
		<div class="modal fade" id="aproposLightbox" tabindex="-1" aria-hidden="true">
			<div
				class="modal-dialog modal-dialog-centered modal-lg">
				{# Supprime "bg-transparent" si le problème persiste, 
				           parfois Bootstrap a besoin d'un fond pour gérer les clics #}
				<div class="modal-content border-0">
					<div
						class="modal-body p-0">
						{# Bouton de fermeture corrigé #}
						<button type="button" class="btn-close btn-close-white position-absolute top-0 end-0 m-3" style="z-index: 1080;" data-bs-dismiss="modal" aria-label="Close"></button>

						<div id="carouselApropos" class="carousel carousel-fade">
							<div class="carousel-inner">
								{% for photo in photos_apropos %}
									<div class="carousel-item {{ loop.first ? 'active' : '' }}">
										<img src="{{ asset('images/Apropos/' ~ photo) }}" class="d-block w-100" alt="Info" style="max-height: 85vh; object-fit: contain;">
									</div>
								{% endfor %}
							</div>

							{# Boutons de navigation #}
							<button class="carousel-control-prev" type="button" data-bs-target="#carouselApropos" data-bs-slide="prev">
								<span class="carousel-control-prev-icon"></span>
							</button>
							<button class="carousel-control-next" type="button" data-bs-target="#carouselApropos" data-bs-slide="next">
								<span class="carousel-control-next-icon"></span>
							</button>
						</div>
					</div>
				</div>
			</div>
		</div>

		{# Section Appel à l'action final #}
		<section class="container my-5 py-5 reveal">
			<div class="rounded-4 p-5 text-center text-white shadow-lg" style="background-color: var(--primary-green);">
				<h2 class="fw-bold mb-3">On coupe, on taille, on embellit.<br>Qu'attendez-vous pour un devis gratuit ?</h2>
				<p class="mb-4 fs-5 opacity-75">Obtenez votre devis gratuit et sans engagement dès aujourd'hui.</p>
				<a href="{{ path('app_devis') }}" class="btn btn-light btn-lg px-5 rounded-pill fw-bold text-success">Devis gratuit →</a>
			</div>
		</section>
	{% endblock %}
