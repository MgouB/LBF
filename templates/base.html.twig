<!doctype html>
<html lang="fr" class="h-100">
    <head>
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>
            {% block title %}LBF Paysage{% endblock %}
        </title>
        
        <link rel="icon" href="{{ asset('images/logo/logo.png') }}" type="image/png">

        {% block stylesheets %}
            {{ encore_entry_link_tags('app') }}
            <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
            <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
        {% endblock %}
    </head>
    <body class="d-flex flex-column h-100 bg-light">
        <header class="bg-white shadow-sm sticky-top">
            <div class="container-fluid px-lg-5">
                <div class="row align-items-center">
                    
                    <div class="col-12 col-md-4 text-center text-md-start py-2">
                        <a href="{{ path('app_accueil') }}">
                            <img src="{{ asset('images/logo/logo_texte.png') }}" style="height:100px; width: auto;" alt="logo LBF">
                        </a>
                    </div>
                    <div class="col-12 col-md-8 d-flex justify-content-center justify-content-md-end align-items-center py-2">
                        <nav> 
                            <ul class="nav align-items-center fw-bold">
                                <li class="nav-item">
                                    <a class="nav-link text-success" href="{{ path('app_devis') }}">DEVIS GRATUIT</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" href="{{ path('app_accueil') }}#a-propos">À PROPOS</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" href="{{ path('app_services') }}">NOS SERVICES</a>
                                </li>
                                {% if is_granted('ROLE_ADMIN') %}
                                    <li class="nav-item ms-lg-3">
                                        <a class="btn btn-outline-success btn-sm fw-bold px-3" href="{{ path('app_profil') }}">
                                            <i class="bi bi-shield-lock-fill"></i> ADMIN
                                        </a>
                                    </li>
                                {% endif %}
                            </ul>
                        </nav>
                    </div>
                </div>
            </div>
        </header>
        <main class="flex-shrink-0">
            {% block body %}
            {% endblock %}
        </main>
        <footer class="main-footer border-top bg-white pt-5 mt-auto shadow-sm">
            <div class="container pb-4">
                <div class="row g-4 text-center text-md-start">
                    <div class="col-md-3">
                        <h5 class="fw-bold mb-3 text-success">LBF Paysage</h5>
                        <p class="small mb-2 text-muted">
                            <i class="bi bi-geo-alt-fill text-success"></i> 21 rue du Docteur Calmette, 59420 MOUVAUX
                        </p>
                        <p class="small mb-2 text-muted">
                            <i class="bi bi-clock-fill text-success"></i> Lun - Ven : 08h00 - 18h00
                        </p>
                        <p class="small mb-2 text-muted">
                            <i class="bi bi-phone-fill text-success"></i> 06 63 97 88 31
                        </p>
                        <p class="small text-muted">
                            <i class="bi bi-envelope-fill text-success"></i> maxence.leboeuf@lbf-paysage.com
                        </p>
                    </div>
                    <div class="col-md-2">
                        <h5 class="fw-bold mb-3">Navigation</h5>
                        <ul class="list-unstyled">
                            <li class="mb-2"><a href="{{ path('app_accueil') }}#a-propos" class="footer-link text-decoration-none text-muted small">À propos</a></li>
                            <li class="mb-2"><a href="{{ path('app_services') }}" class="footer-link text-decoration-none text-muted small">Nos services</a></li>
                            <li class="mb-2"><a href="{{ path('app_devis') }}" class="footer-link text-decoration-none text-success small fw-bold">Devis gratuit</a></li>
                        </ul>
                    </div>
                    <div class="col-md-3 text-center">
                        <h5 class="fw-bold mb-3">Suivez-nous</h5>
                        <div class="d-flex justify-content-center gap-3">
                            <a href="https://www.facebook.com/people/LBF-paysage/61551084158185/" class="fs-4 text-dark"><i class="bi bi-facebook"></i></a>
                            <a href="https://www.instagram.com/lbfpaysage/" class="fs-4 text-dark"><i class="bi bi-instagram"></i></a>
                            <a href="https://www.youtube.com/@LBFpaysage" class="fs-4 text-dark"><i class="bi bi-youtube"></i></a>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <h5 class="fw-bold mb-3">Zone d'intervention</h5>
                        <div class="rounded-4 shadow-sm overflow-hidden border" style="height: 160px;">
                            <iframe 
                                width="100%" height="100%" frameborder="0" scrolling="no" 
                                marginheight="0" marginwidth="0" 
                                src="https://maps.google.com/maps?q=21%20rue%20du%20Docteur%20Calmette%2C%2059420%20MOUVAUX&t=&z=14&ie=UTF8&iwloc=&output=embed">
                            </iframe>
                        </div>
                    </div>
                </div>
                <div class="text-center mt-5 pt-4 border-top small text-muted">
                    &copy; 2026 LBF Paysage – Tous droits réservés – 
                    <a href="#" class="text-muted text-decoration-none">Mentions légales</a>
                </div>
            </div>
        </footer>

        {% block javascripts %}
            {{ encore_entry_script_tags('app') }}
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
        {% endblock %}
    </body>
</html>